# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Explicitly declare text files to normalize
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.sh text eol=lf
*.bicep text eol=lf
*.xml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.lock text eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar.gz binary
